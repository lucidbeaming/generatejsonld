{
  "name": "generatejsonld",
  "version": "1.0.0",
  "description": "Scrape a website and generate JSON-LD structured data for each page using AI",
  "type": "module",
  "main": "index.js",
  "bin": {
    "generatejsonld": "./index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test",
    "lint": "eslint src/ index.js",
    "lint:fix": "eslint src/ index.js --fix",
    "format": "prettier --write src/ index.js *.js *.json",
    "format:check": "prettier --check src/ index.js *.js *.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucidbeaming/generatejsonld.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/lucidbeaming/generatejsonld/issues"
  },
  "homepage": "https://github.com/lucidbeaming/generatejsonld#readme",
  "dependencies": {
    "@mistralai/mistralai": "^1.3.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "playwright": "^1.44.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
