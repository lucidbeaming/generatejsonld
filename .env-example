# generatejsonld — environment configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Mistral AI (default provider) ──────────────────────────────────────────
# Get your key at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Alternative: Anthropic Claude ──────────────────────────────────────────
# To switch to Anthropic, update src/generator.js to use @anthropic-ai/sdk.
# Replace the Mistral client init and message format with the Anthropic SDK:
#   import Anthropic from '@anthropic-ai/sdk';
#   const client = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });
#   const response = await client.messages.create({ model, max_tokens, system, messages });
# Get your key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Alternative: OpenAI ────────────────────────────────────────────────────
# To switch to OpenAI, update src/generator.js to use the openai npm package.
#   import OpenAI from 'openai';
#   const client = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });
#   const response = await client.chat.completions.create({ model, messages, response_format });
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# ── Optional overrides ─────────────────────────────────────────────────────
# Default model is mistral-large-latest. Override here or via --model flag.
# MISTRAL_MODEL=mistral-large-latest
